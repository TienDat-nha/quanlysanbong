REACT_APP_API_URL=https://api-be-football.onrender.com
# Backend hien tai khong co API danh sach san cong khai.
# Dien cac field id can hien thi, ngan cach bang dau phay.
# Vi du: REACT_APP_FIELD_IDS=65f123...,65f456...
REACT_APP_FIELD_IDS=
# Tai lieu BE hien tai chua co API OTP/mail.
# Cau hinh EmailJS de gui OTP mail khi admin tao tai khoan.
# Template nen dung cac bien: {{to_email}}, {{otp_code}}, {{user_name}},
# {{account_role}}, {{admin_email}}, {{expires_in_minutes}}.
REACT_APP_EMAILJS_SERVICE_ID=
REACT_APP_EMAILJS_TEMPLATE_ID=
REACT_APP_EMAILJS_PUBLIC_KEY=
